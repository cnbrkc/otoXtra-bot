```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Dependencies
venv/
.venv/
node_modules/

# Build/dist directories
dist/
build/
target/

# Coverage reports
coverage/
htmlcov/
.coverage

# OS files
.DS_Store
Thumbs.db
```