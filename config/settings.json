{
  "posting": {
    "max_daily_posts": 9,
    "random_delay_max_minutes": 0,
    "min_post_interval_hours": 1,
    "skip_probability_percent": 0,
    "max_posts_per_run": 1
  },
  "images": {
    "add_logo": true,
    "logo_position": "bottom_right",
    "logo_opacity": 0.7,
    "logo_size_percent": 15,
    "feed_image_width": 1200,
    "feed_image_height": 630,
    "enable_article_image_scrape": true,
    "max_candidates_per_article": 12,
    "max_article_scrapes_per_feed": 6,
    "max_images_per_news": 4
  },
  "news": {
    "max_article_age_hours": 16,
    "max_articles_per_source": 10,
    "min_summary_length": 30
  },
  "duplicate_detection": {
    "title_similarity_threshold": 0.8,
    "keyword_overlap_threshold": 0.7
  },
  "ai": {
    "temperature": 0.65,
    "max_output_tokens": 1400,
    "enable_gemini": true,
    "gemini_model": "gemini-2.5-flash-lite",
    "groq_model": "llama-3.3-70b-versatile"
  }
}
