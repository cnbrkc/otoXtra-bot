{
  "posting": {
    "max_daily_posts": 10,
    "random_delay_max_minutes": 5,
    "min_post_interval_hours": 0,
    "min_post_interval_minutes": 30,
    "skip_probability_percent": 0,
    "max_posts_per_run": 1,
    "dry_run": false,
    "feed_fetch_delay_seconds": 0.35,
    "feed_fetch_delay_jitter_seconds": 0.4,
    "feed_fetch_attempts": 1,
    "feed_http_attempts": 3,
    "feed_http_base_wait_seconds": 1.5,
    "feed_http_timeout_seconds": 20,
    "nitter_feed_fetch_attempts": 3,
    "nitter_http_attempts": 3,
    "nitter_http_base_wait_seconds": 1.8,
    "nitter_http_timeout_seconds": 22
  },
  "images": {
    "add_logo": true,
    "logo_position": "bottom_right",
    "logo_opacity": 0.7,
    "logo_size_percent": 12,
    "feed_image_width": 1200,
    "feed_image_height": 630,
    "enable_article_image_scrape": true,
    "max_candidates_per_article": 20,
    "max_article_scrapes_per_feed": 10,
    "max_images_per_news": 4,
    "perceptual_hash_threshold": 8,
    "enable_fetch_article_image_scrape": false
  },
  "news": {
    "max_article_age_hours": 24,
    "max_articles_per_source": 10,
    "min_summary_length": 30,
    "shared_variant_cooldown_hours": 3
  },
  "duplicate_detection": {
    "title_similarity_threshold": 0.8,
    "keyword_overlap_threshold": 0.7
  },
  "ai": {
    "temperature": 0.65,
    "max_output_tokens": 1400,
    "enable_gemini": true,
    "enable_groq": true,
    "enable_openrouter": true,
    "enable_huggingface": true,
    "retry_attempts": 2,
    "retry_base_wait_seconds": 3.0,
    "retry_max_wait_seconds": 10.0,
    "gemini_model": "gemini-exp-1206",
    "groq_model": "llama-3.3-70b-versatile",
    "openrouter_model": "openai/gpt-4o-mini",
    "hf_model": "mistralai/Mistral-7B-Instruct-v0.2"
  },
  "threads": {
    "enabled": false,
    "mode": "text_only"
  }
}
